# Required for the AI Tour Planner (/tour-planner) — server-side only, never exposed to the browser.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Required for the News/Blog section (/news) — server-side only, never exposed to the browser.
# Create an internal integration at https://www.notion.so/my-integrations to get a token,
# then share your news database with that integration.
NOTION_TOKEN=

# The Notion database ID for the news/blog posts (the 32-character ID in the database URL).
# Expected database columns: Title (title), Date (date), Published (checkbox),
# an image/file property (files) or a page cover image, and optionally a
# "Locale" select property (ka/en/ru) to scope posts to a specific language.
NOTION_DATABASE_ID=

# Required for the /menu ordering page — server-side only, never exposed to the browser.
# Create a bot via https://t.me/BotFather to get a token. Orders are sent to the
# fixed chat ID configured in src/lib/constants.ts (TELEGRAM_ORDER_CHAT_ID).
TELEGRAM_BOT_TOKEN=
